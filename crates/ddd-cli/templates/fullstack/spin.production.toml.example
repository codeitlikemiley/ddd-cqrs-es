[component.auth-api.build]
command = "bash scripts/verify_toolchain.sh && WASI_RUNTIME=spin AUTH_TRANSPORT=both LEPTOS_OUTPUT_NAME=fullstack_app cargo build --lib --target wasm32-wasip2 --release --no-default-features --features ${FULLSTACK_FEATURES:-ssr,postgres,spin-grpc,mail-http} && bash scripts/verify_wasi_artifact.sh"
