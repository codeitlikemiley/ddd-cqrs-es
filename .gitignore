# Generated by Cargo
# will have compiled files and executables
target/
node_modules/
.spin/

# This workspace publishes the `ddd` executable, and CI/release commands use
# `--locked`; keep the root lockfile reproducible even though other lock files
# remain ignored below.

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds
*.pdb

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS specific
.DS_Store
Thumbs.db
*.lock
!Cargo.lock
