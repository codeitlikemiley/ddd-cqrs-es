[component.auth-api.build]
command = "WASI_RUNTIME=spin AUTH_TRANSPORT=both cargo build --lib --target wasm32-wasip2 --release --no-default-features --features ${AUTH_STACK_FEATURES:-ssr,sqlite,spin-grpc}"
