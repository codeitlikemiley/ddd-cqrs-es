# Database Selection
# Supported make backends: sqlite, postgres, neon, supabase, turso
DATABASE_BACKEND=sqlite

# make derives DATABASE_URL/DATABASE_AUTH_TOKEN from the backend-specific
# values below before launching Spin or Wasmtime.

# =========================================================================
# 1. PostgreSQL Settings (Local PostgreSQL)
# =========================================================================
# Used when running make db=postgres ...
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres

# =========================================================================
# 2. Neon Settings
# =========================================================================
# Used when running make db=neon ...
NEON_DB_URL=

# =========================================================================
# 3. Supabase Settings
# =========================================================================
# Supabase API URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=
# Supabase Service Role Secret Key (service_role bypasses RLS)
SUPABASE_SECRET_KEY=

# =========================================================================
# 4. LibSQL / Turso Settings (HTTP API)
# =========================================================================
# Turso Remote DB or Local sqld HTTP URL
# Example: https://my-db-username.turso.io (remote) or http://127.0.0.1:8080 (local)
TURSO_URL=
# Turso authorization token (leave empty for local sqld/development)
TURSO_AUTH_TOKEN=
