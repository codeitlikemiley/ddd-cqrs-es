# Database Selection
# Supported backends: sqlite, postgres, neon, supabase, libsql, turso
DATABASE_BACKEND=sqlite

# =========================================================================
# 1. PostgreSQL Settings (Local PostgreSQL / Supabase / Neon)
# =========================================================================
# Used under Spin (native pg client) or custom native postgres clients
# Example: postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres

# =========================================================================
# 2. Supabase Settings
# =========================================================================
# Supabase API URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=
# Supabase Publishable Key
SUPABASE_PUBLISHABLE_KEY=
# Supabase Service Role Secret Key
SUPABASE_SECRET_KEY=
# Supabase JWKS URL for token verification
SUPABASE_JWKS_URL=

# =========================================================================
# 3. LibSQL / Turso Settings (HTTP API)
# =========================================================================
# Turso Remote DB or Local sqld HTTP URL
# Example: https://my-db-username.turso.io (remote) or http://127.0.0.1:8080 (local)
TURSO_URL=
# Turso authorization token (leave empty for local sqld/development)
TURSO_AUTH_TOKEN=

